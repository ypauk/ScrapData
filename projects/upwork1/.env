# Режим запуска браузера: 1 — в фоне (для Docker/сервера), 0 — с показом экрана (для дебага)
HEADLESS=0

# Флаг, сообщающий коду, что запуск происходит внутри Docker-контейнера
IS_DOCKER=0

# Максимальное время ожидания загрузки страниц (в секундах)
SCRAPER_TIMEOUT=30

# Количество повторных попыток при сбое запроса
SCRAPER_RETRY=3

# Настройки прокси (если не нужны, оставьте пустой или закомментируйте)
# PROXY_URL=http://username:password@host:port

# File Proxy Provider (app/file_proxy_provider.py)
# PROXY_FILE_PATH=AI_INPUT/proxies.txt
# PROXY_FILE_DEFAULT_SCHEME=http

# Webshare Proxy Provider (app/webshare_proxy_provider.py)
# Получить API-ключ: https://proxy.webshare.io/ -> Dashboard -> API
WEBSHARE_API_KEY=6d8rkntdnvn88vwha8kqfwfrwn675k59qt5rdokv
# WEBSHARE_API_URL=https://proxy.webshare.io/api/v2/proxy/list/
# WEBSHARE_CACHE_TTL_SECONDS=300
# WEBSHARE_API_TIMEOUT=30

# Proxy Cache (app/proxy_cache.py) — персистентный файловый кэш списка прокси,
# используемый через CachedProxyProvider (обертка над Webshare/File Provider)
# PROXY_CACHE_FILE_PATH=AI_INPUT/proxy_cache.json
# PROXY_CACHE_TTL_SECONDS=300

# Proxy Selection (app/proxy_selector.py) — стратегия выбора одного прокси
# из пула, предоставленного провайдером: "first" или "random"
# PROXY_SELECTION_STRATEGY=first

# Proxy Rotation (app/proxy_rotation.py) — политика, определяющая, КОГДА
# менять текущий прокси: "never", "every_request", "every_n_requests"
# или "after_failure"
# PROXY_ROTATION_POLICY=every_request
# PROXY_ROTATION_EVERY_N=5

# Proxy Health Check (app/health_check.py) — пороги мониторинга здоровья прокси.
# HEALTH_CHECK_URL=https://httpbin.org/ip
# HEALTH_CHECK_TIMEOUT=10
# HEALTH_MAX_CONSECUTIVE_FAILURES=5
# HEALTH_UNHEALTHY_CONSECUTIVE_FAILURES=2
# HEALTH_MIN_SUCCESS_RATE=0.5
# HEALTH_MIN_REQUESTS_FOR_RATE=10
# HEALTH_MAX_RESPONSE_TIME_MS=5000
# HEALTH_DISABLE_DURATION_SECONDS=300

# Sticky Sessions (app/sticky_sessions.py) — привязка одного прокси к одной
# логической сессии (job/сайт/логин/браузер/API), передаваемой в
# ProxyManager.get_proxy(session_id=...).
# STICKY_SESSIONS_ENABLED=1
# STICKY_SESSION_TIMEOUT_SECONDS=600
# STICKY_SESSION_MAX_REQUESTS=100
# STICKY_SESSION_ON_FAILURE=replace



# Кастомный User-Agent для requests и Playwright (если не задан — используется дефолтный)
# SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36

# Локаль и часовой пояс браузерного контекста (Playwright) / заголовков запросов
# BROWSER_LOCALE=en-US
# BROWSER_TIMEZONE=America/New_York

# Размер окна браузера (viewport) для Playwright
# BROWSER_VIEWPORT_WIDTH=1920
# BROWSER_VIEWPORT_HEIGHT=1080

# --- Request Profile Manager: HTTP-заголовки браузерной идентичности ---
# Используются app/request_profile.py для сборки полного профиля (Requests + Playwright)
# SCRAPER_ACCEPT=text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8
# SCRAPER_ACCEPT_LANGUAGE=en-US,en;q=0.9
# SCRAPER_ACCEPT_ENCODING=gzip, deflate, br
# SCRAPER_CONNECTION=keep-alive
# SCRAPER_UPGRADE_INSECURE_REQUESTS=1
# SCRAPER_SEC_FETCH_DEST=document
# SCRAPER_SEC_FETCH_MODE=navigate
# SCRAPER_SEC_FETCH_SITE=none
# SCRAPER_DNT=1

# Pagination (app/pagination.py) — централизованный компонент пагинации.
# Не хранит селекторы сайтов, только стратегию и лимиты.
# PAGINATION_MAX_PAGES=0
# PAGINATION_TIMEOUT_SECONDS=0
# PAGINATION_DUPLICATE_DETECTION=0
# PAGINATION_PAGE_PARAM=page
# PAGINATION_START_PAGE=1
# PAGINATION_PAGE_STEP=1
# PAGINATION_OFFSET_PARAM=offset
# PAGINATION_START_OFFSET=0
# PAGINATION_OFFSET_STEP=20
# PAGINATION_DELAY_MODE=random
# PAGINATION_DELAY_FIXED_SECONDS=2.0
# PAGINATION_DELAY_MIN_SECONDS=1.0
# PAGINATION_DELAY_MAX_SECONDS=3.0

# Login Support (app/login_manager.py) — централизованный компонент аутентификации.
# Не хранит учетные данные/URL/селекторы сайтов, только лимиты и тайм-ауты.
# LOGIN_MAX_ATTEMPTS=3
# LOGIN_TIMEOUT_SECONDS=30
# LOGIN_SESSION_LIFETIME_SECONDS=1800
# LOGIN_COOKIE_PERSISTENCE=1
# LOGIN_BEARER_HEADER_NAME=Authorization
# LOGIN_API_KEY_HEADER_NAME=X-API-Key
# LOGIN_CAPTCHA_KEYWORDS=captcha,recaptcha,hcaptcha,are you a robot

# Resume Support (app/resume_manager.py) — автоматическое продолжение
# прерванной сессии скрапинга на основе чекпоинтов Checkpoint Manager.
# RESUME_ENABLED=1
# RESUME_MAX_AGE_SECONDS=0
# RESUME_CONFIRMATION_REQUIRED=0




